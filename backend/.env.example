# ElectricityMaps free-tier API key: https://portal.electricitymaps.com/
ELECTRICITYMAPS_API_KEY=

# Optional, tried first: Fireworks AI serves several models on real AMD
# Instinct MI300X hardware, so this makes the agent's own reasoning run on
# AMD compute. OpenAI-compatible API. https://app.fireworks.ai/
FIREWORKS_API_KEY=
FIREWORKS_MODEL=accounts/fireworks/models/llama-v3p1-70b-instruct

# Optional, tried second if no Fireworks key. Without either, the agent
# falls back to a regex-based parser for the workload text box.
ANTHROPIC_API_KEY=

# Shared secret the GPU poller must send in the X-Ingest-Key header.
INGEST_SHARED_SECRET=dev-secret-change-me

# Comma-separated list of allowed CORS origins for the frontend dev server.
CORS_ORIGINS=http://localhost:5173
